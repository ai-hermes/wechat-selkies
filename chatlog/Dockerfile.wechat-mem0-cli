# syntax=docker/dockerfile:1

FROM ai-insight-cr-cn-beijing.cr.volces.com/container/golang:1.24-bookworm AS builder

WORKDIR /src
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
#RUN bash <(curl -sSL https://linuxmirrors.cn/docker.sh)
RUN bash <(curl -sSL https://linuxmirrors.cn/main-lite.sh) --source mirrors.aliyun.com
RUN go env -w GO111MODULE=on && go env -w GOPROXY=https://goproxy.cn,direct
# Install cross toolchain and arm64 C dependencies for CGO (go-sqlite3).
RUN dpkg --add-architecture arm64 \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
       ca-certificates \
       pkg-config \
       gcc-aarch64-linux-gnu \
       g++-aarch64-linux-gnu \
       libc6-dev-arm64-cross \
       libsqlite3-dev:arm64 \
    && rm -rf /var/lib/apt/lists/*

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ENV CGO_ENABLED=1 \
    GOOS=linux \
    GOARCH=arm64 \
    CC=aarch64-linux-gnu-gcc \
    CXX=aarch64-linux-gnu-g++ \
    PKG_CONFIG_PATH=/usr/lib/aarch64-linux-gnu/pkgconfig \
    PKG_CONFIG_LIBDIR=/usr/lib/aarch64-linux-gnu/pkgconfig:/usr/share/pkgconfig

RUN go build -o /out/wechat-mem0-core ./cmd/wechat-mem0-core

FROM ai-insight-cr-cn-beijing.cr.volces.com/container/golang:1.24-bookworm AS export-bin
COPY --from=builder /out/wechat-mem0-cli /wechat-mem0-cli


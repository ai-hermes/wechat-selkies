# syntax=docker/dockerfile:1

FROM ai-insight-cr-cn-beijing.cr.volces.com/container/golang:1.24-bookworm AS builder

WORKDIR /src
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
#RUN bash <(curl -sSL https://linuxmirrors.cn/docker.sh)
RUN bash <(curl -sSL https://linuxmirrors.cn/main-lite.sh) --source mirrors.aliyun.com
RUN go env -w GO111MODULE=on && go env -w GOPROXY=https://goproxy.cn,direct
# Buildx provides TARGETOS/TARGETARCH for each platform.
ARG TARGETOS
ARG TARGETARCH

# Install native C toolchain and sqlite headers for CGO build.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       ca-certificates \
       pkg-config \
       gcc \
       g++ \
       libsqlite3-dev \
    && rm -rf /var/lib/apt/lists/*

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ENV CGO_ENABLED=1 \
    GOOS=${TARGETOS} \
    GOARCH=${TARGETARCH}

RUN go build -o /out/wechat-mem0-core ./cmd/wechat-mem0-core

FROM scratch AS export-bin
COPY --from=builder /out/wechat-mem0-core /wechat-mem0-core

